FROM vllm/vllm-openai:v0.8.4

# Model is pre-baked into image - no GCS download needed
# For baked deployment, build image with model included for faster startup

ENV MODEL_NAME="qwen3-8b-awq"
ENV PORT=8080
ENV PYTHONUNBUFFERED=1

# Copy pre-downloaded model into image
COPY models/${MODEL_NAME} /models/${MODEL_NAME}

COPY startup-baked.sh /startup.sh
RUN chmod +x /startup.sh

EXPOSE ${PORT}
ENTRYPOINT ["/startup.sh"]
